================================================================================
KEY CONFIGURATION VARIABLES
================================================================================

REQUIRED:
- hcloud_token          # Hetzner Cloud API token
- ssh_public_key        # SSH public key for server access

IMPORTANT SECURITY SETTINGS:
- allowed_ssh_cidr      # RESTRICT TO YOUR IP! (default: 0.0.0.0/0 - DANGEROUS)
- control_plane_count   # Odd numbers only (1, 3, 5, 7) for etcd quorum
- region                # fsn1, nbg1, hel1, ash, hil

CLUSTER CONFIGURATION:
- cluster_name          # Default: "rke2"
- environment           # dev, staging, prod (default: prod)
- control_plane_count   # Default: 3
- worker_count          # Default: 2
- control_plane_server_type  # Default: cpx21
- worker_server_type    # Default: cpx31

NETWORK:
- network_cidr          # Default: 10.0.0.0/16
- control_plane_subnet  # Default: 10.0.1.0/24
- worker_subnet         # Default: 10.0.2.0/24
- load_balancer_subnet  # Default: 10.0.3.0/24

RKE2 CONFIGURATION:
- rke2_version          # Default: v1.29.3+rke2r1
- rke2_cni              # cilium (default), canal, calico, flannel, none
- rke2_cis_profile      # "" (disabled) or "cis" or "cis-1.23"
- rke2_token            # Auto-generated if empty

FEATURES:
- enable_hccm           # Default: true (Hetzner Cloud Controller)
- enable_csi_driver     # Default: true (Hetzner CSI)
- enable_backups        # Default: true (for CP nodes)
- enable_auto_updates   # Default: true (security patches)

